    "description": "A modern remote terminal workspace",
    "homepage": "https://nyaterm.app/",
    "license": {
        "identifier": "MIT license",
        "url": "https://github.com/nyakang/nyaterm#MIT-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/KaringX/karing/releases/download/v1.2.21.2408/karing_1.2.21.2408_windows_x64.exe",
            "hash": "37c2c0f52510dd19a0bef3ff9e8f159f7d9214f47b61cd12be160297e62615ed"
        },
        "arm64": {
            "url": "https://github.com/KaringX/karing/releases/download/v1.2.21.2408/karing_1.2.21.2408_windows_x64.exe",
            "hash": "37c2c0f52510dd19a0bef3ff9e8f159f7d9214f47b61cd12be160297e62615ed"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninst*\" -Force -Recurse",
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:USERPROFILE\\.nyaterm\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.nyaterm\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "nyaterm.exe",
    "shortcuts": [
        [
            "nyaterm.exe",
            "NyaTerm"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/nyakang/nyaterm/releases/latest",
        "jp": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nyakang/nyaterm/releases/download/v$version/NyaTerm_$version_windows_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/nyakang/nyaterm/releases/download/v$version/NyaTerm_$version_windows_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.json"
        }
    }
}
